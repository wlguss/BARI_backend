    {
      "name": "매장 - 주문 관리 API (order-service :8086)",
      "description": "⚠️ store-service 연동 전까지 동작하지 않습니다.",
      "item": [
        {
          "name": "주문 목록 조회 (매장)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-User-Id",   "value": "{{user_id}}" },
              { "key": "X-User-Role", "value": "OWNER" }
            ],
            "url": {
