    {
      "name": "api-gateway 경유 (:8080)",
      "description": "api-gateway를 통해 호출합니다.\nBearer 토큰으로 인증하면 gateway가 X-Header로 변환하여 각 서비스로 라우팅합니다.",
      "item": [
        {
          "name": "[gateway] 로그인",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data) {",
                  "  pm.collectionVariables.set('access_token', res.data.accessToken);",
                  "  pm.collectionVariables.set('refresh_token', res.data.refreshToken);",
                  "  pm.collectionVariables.set('user_id', String(res.data.userId));",
                  "  console.log('gateway 로그인 완료 - userId:', res.data.userId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{gateway_url}}/api/auth/login",
              "host": ["{{gateway_url}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user1@bari.com\",\n  \"password\": \"p1234\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "[gateway] 매장 목록 조회",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{gateway_url}}/api/stores",
              "host": ["{{gateway_url}}"],
              "path": ["api", "stores"]
            }
          }
        },
        {
          "name": "[gateway] 상품 목록 조회",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{gateway_url}}/api/products?storeId=1",
              "host": ["{{gateway_url}}"],
              "path": ["api", "products"],
              "query": [{ "key": "storeId", "value": "1" }]
            }
          }
        },
        {
          "name": "[gateway] 주문 목록 조회",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{gateway_url}}/api/orders",
              "host": ["{{gateway_url}}"],
              "path": ["api", "orders"]
            }
          }
        }
      ]
    }
  ]
}
