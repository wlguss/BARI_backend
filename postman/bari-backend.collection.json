              "raw": "{\n  \"name\": \"바리 베이커리\",\n  \"description\": \"매일 신선한 빵을 판매합니다.\",\n  \"address\": \"서울시 강남구 테헤란로 123\",\n  \"phone\": \"02-1234-5678\",\n  \"businessHours\": \"09:00 - 20:00\",\n  \"category\": \"베이커리\",\n  \"imageUrl\": \"\"\n}",
              "options": { "raw": { "language": "json" } }
