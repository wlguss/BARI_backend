            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-Id", "value": "{{user_id}}" },
              { "key": "X-User-Role", "value": "OWNER" }
            ],
            "url": {
              "raw": "{{store_service_url}}/api/stores/1",
              "host": ["{{store_service_url}}"],
              "path": ["api", "stores", "1"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"바리 베이커리 (수정)\",\n  \"description\": \"업데이트된 설명입니다.\",\n  \"address\": \"서울시 강남구 테헤란로 123\",\n  \"phone\": \"02-1234-5678\",\n  \"businessHours\": \"10:00 - 21:00\",\n  \"category\": \"베이커리\",\n  \"imageUrl\": \"\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "매장 삭제",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "X-User-Id", "value": "{{user_id}}" },
              { "key": "X-User-Role", "value": "OWNER" }
            ],
            "url": {
              "raw": "{{store_service_url}}/api/stores/1",
              "host": ["{{store_service_url}}"],
              "path": ["api", "stores", "1"]
            }
          }
        }
      ]
    },
