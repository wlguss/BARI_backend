{
  "info": {
    "name": "bari-backend",
    "_postman_id": "bari-backend-collection-v2",
    "description": "bari-backend MSA API Collection\n\n[사용 방법]\n1. 로그인 API 호출 → accessToken, refreshToken, userId 자동 저장\n2. 이후 인증 필요 API는 변수가 자동 적용됩니다.\n\n[변수]\n- user_service_url    : localhost:8081\n- store_service_url   : localhost:8082\n- product_service_url : localhost:8083\n- order_service_url   : localhost:8086\n- gateway_url         : localhost:8080\n- access_token        : 로그인 후 자동 저장\n- refresh_token       : 로그인 후 자동 저장\n- user_id             : 로그인 후 자동 저장",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "user_service_url",    "value": "http://localhost:8081", "type": "string" },
    { "key": "store_service_url",   "value": "http://localhost:8082", "type": "string" },
    { "key": "product_service_url", "value": "http://localhost:8083", "type": "string" },
    { "key": "order_service_url",   "value": "http://localhost:8086", "type": "string" },
    { "key": "gateway_url",         "value": "http://localhost:8080", "type": "string" },
    { "key": "access_token",        "value": "", "type": "string" },
    { "key": "refresh_token",       "value": "", "type": "string" },
    { "key": "user_id",             "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "인증 API (user-service :8081)",
      "item": [
        {
          "name": "회원가입 - 일반 사용자",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{user_service_url}}/api/auth/signup",
              "host": ["{{user_service_url}}"],
              "path": ["api", "auth", "signup"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@bari.com\",\n  \"password\": \"p1234\",\n  \"passwordConfirm\": \"p1234\",\n  \"nickname\": \"테스트유저\",\n  \"role\": \"USER\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "회원가입 - 매장 사장님",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{user_service_url}}/api/auth/signup",
              "host": ["{{user_service_url}}"],
              "path": ["api", "auth", "signup"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner@bari.com\",\n  \"password\": \"p1234\",\n  \"passwordConfirm\": \"p1234\",\n  \"nickname\": \"사장님\",\n  \"role\": \"OWNER\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "로그인",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data) {",
                  "  pm.collectionVariables.set('access_token', res.data.accessToken);",
                  "  pm.collectionVariables.set('refresh_token', res.data.refreshToken);",
                  "  pm.collectionVariables.set('user_id', String(res.data.userId));",
                  "  console.log('로그인 완료 - userId:', res.data.userId, 'role:', res.data.role);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{user_service_url}}/api/auth/login",
              "host": ["{{user_service_url}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user1@bari.com\",\n  \"password\": \"p1234\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "토큰 갱신",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data) {",
                  "  pm.collectionVariables.set('access_token', res.data.accessToken);",
                  "  pm.collectionVariables.set('refresh_token', res.data.refreshToken);",
                  "  console.log('토큰 갱신 완료');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{refresh_token}}" }],
            "url": {
              "raw": "{{user_service_url}}/api/auth/refresh",
              "host": ["{{user_service_url}}"],
              "path": ["api", "auth", "refresh"]
            }
          }
        },
        {
          "name": "로그아웃",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{user_service_url}}/api/auth/logout",
              "host": ["{{user_service_url}}"],
              "path": ["api", "auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "사용자 API (user-service :8081)",
      "item": [
        {
          "name": "내 정보 조회",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{user_service_url}}/api/users/me",
              "host": ["{{user_service_url}}"],
              "path": ["api", "users", "me"]
            }
          }
        },
        {
          "name": "회원 탈퇴",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{user_service_url}}/api/users/me",
              "host": ["{{user_service_url}}"],
              "path": ["api", "users", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "매장 API (store-service :8082)",
