# 로컬(gradlew bootRun) 실행 시 각 서비스에 주입되는 환경변수 템플릿
# 사용법: cp .env.example .env  후 값 채우기
# .env는 .gitignore에 의해 git에 커밋되지 않는다.
# (docker/.env는 별도 파일이며 docker-compose 인프라 전용이다)

# ===== MariaDB (docker/.env의 MYSQL_USER/MYSQL_DATABASE와 동일한 값으로 맞출 것) =====
DB_HOST=localhost
DB_PORT=3306
DB_NAME=bari
DB_USERNAME=bari
DB_PASSWORD=bari1234

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379

# ===== JWT (32자 이상 필수) =====
JWT_SECRET=bari-super-secret-key-must-be-at-least-32-chars

# ===== Kafka =====
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ===== AWS S3 (product-service, 로컬에서 이미지 업로드 테스트 시에만 필요) =====
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_S3_BUCKET=bari-product-images
